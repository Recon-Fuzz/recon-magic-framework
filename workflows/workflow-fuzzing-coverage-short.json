{
  "name": "Fuzzing Coverage Workflow",
  "steps": [
    {
      "name": "Step 11: Run Echidna Programmatically",
      "type": "task",
      "description": "Run Echidna programmatically and capture output",
      "prompt": "(set -o pipefail; echidna . --contract CryticTester --config echidna.yaml --format text --timeout 1800 --test-limit 99999999999999999999 --disable-slither --test-mode exploration 2>&1 | tee echidna-output.log; echo \"ECHIDNA_EXIT_CODE=$?\" > echidna-exit-code.txt) || true",
      "model": {
        "type": "PROGRAM",
        "model": "inherit"
      },
      "allowFailure": true,
      "shouldCreateSummary": false,
      "shouldCommitChanges": true
    },
    {
      "name": "Step 12: Analyze Echidna Output",
      "type": "task",
      "description": "Analyze Echidna execution results and determine next action",
      "prompt": "EXIT_CODE=$(grep 'ECHIDNA_EXIT_CODE=' echidna-exit-code.txt | cut -d'=' -f2); analyze-echidna-output $EXIT_CODE --log-file echidna-output.log --return-json",
      "model": {
        "type": "PROGRAM",
        "model": "inherit"
      },
      "output": {
        "capture": true,
        "save_to": "magic/echidna-error-analysis.json"
      },
      "allowFailure": true,
      "shouldCreateSummary": false,
      "shouldCommitChanges": false
    },
    {
      "name": "Step 12a: Handle Echidna Results",
      "type": "decision",
      "description": "Take action based on Echidna analysis results",
      "mode": "JSON_KEY_VALUE",
      "modeInfo": {
        "fileName": "magic/echidna-error-analysis.json",
        "keyPath": "echidna_exit_code"
      },
      "decision": [
        {
          "operator": "eq",
          "value": 0,
          "action": "JUMP_TO_STEP",
          "destinationStep": "Step 13: Generate Functions to Cover",
          "NOTE": "Echidna ran successfully, skip error handling and continue workflow"
        },
        {
          "operator": "neq",
          "value": 0,
          "action": "JUMP_TO_STEP",
          "destinationStep": "Step 12b: Check Error Type",
          "NOTE": "Echidna failed, need to check error type"
        }
      ],
      "shouldCreateSummary": false,
      "shouldCommitChanges": false
    },
    {
      "name": "Step 12b: Check Error Type",
      "type": "decision",
      "description": "Determine if error is compilation-related",
      "mode": "JSON_KEY_VALUE",
      "modeInfo": {
        "fileName": "magic/echidna-error-analysis.json",
        "keyPath": "requires_compilation_fix"
      },
      "decision": [
        {
          "operator": "eq",
          "value": 1,
          "action": "JUMP_TO_STEP",
          "destinationStep": "Step 12c: Fix Compilation Errors",
          "NOTE": "Compilation error detected, triggering fix agent"
        },
        {
          "operator": "eq",
          "value": 0,
          "action": "STOP",
          "NOTE": "Non-compilation error detected, stopping workflow"
        }
      ],
      "shouldCreateSummary": true,
      "shouldCommitChanges": false
    }
  ]
}