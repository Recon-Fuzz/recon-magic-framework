{
  "name": "Jump Example Workflow",
  "steps": [
    {
      "type": "decision",
      "name": "Step 2: Check if we should skip",
      "description": "Check skip.txt to decide whether to skip intermediate steps",
      "mode": "USE_MODEL",
      "modeInfo": {
        "prompt": "Read skip.txt and pick the most relevant option based on the content"
      },
      "model": {
        "type": "PROGRAM",
        "model": "inherit"
      },
      "shouldCreateSummary": false,
      "shouldCommitChanges": false,
      "decision": [
        {
          "operator": "eq",
          "value": 0,
          "action": "JUMP_TO_STEP",
          "destinationStep": "Step 4: Intermediate work B"
        },
        {
          "operator": "eq",
          "value": 1.0,
          "action": "CONTINUE"
        }
      ]
    },
    {
      "type": "task",
      "name": "Step 3: Intermediate work A",
      "description": "This step may be skipped",
      "prompt": "echo 'Doing intermediate work A'",
      "model": {
        "type": "PROGRAM",
        "model": "inherit"
      },
      "shouldCreateSummary": false,
      "shouldCommitChanges": false
    },
    {
      "type": "task",
      "name": "Step 4: Intermediate work B",
      "description": "This step may also be skipped",
      "prompt": "echo 'Doing intermediate work B'",
      "model": {
        "type": "PROGRAM",
        "model": "inherit"
      },
      "shouldCreateSummary": false,
      "shouldCommitChanges": false
    }
  ]
}
