
{
    "name": "Counter Workflow",
    "steps": [
        {
            "name": "Run the Counter",
            "type": "task",
            "description": "Issues Generation",
            "prompt": "uv run ./programs/increase_counter.py",
            "model": {
                "type": "PROGRAM",
                "model": "inherit"
            },
            "shouldCreateSummary": true,
            "shouldCommitChanges": true
        },
        {
            "name": "Check the Counter",
            "type": "decision",
            "description": "If counter is less than 10, continue, otherwise stop",

            "mode": "READ_FILE",
            "modeInfo": {
                "fileName": "Counter.MD"
            },
            "decision": [
                {
                    "operator": "lt",
                    "value": 10,
                    "action": "CONTINUE"
                },
                {
                    "operator": "gte",
                    "value": 10,
                    "action": "STOP"
                }
            ],

            "shouldCreateSummary": false,
            "shouldCommitChanges": false,
            "prompt": "Ignored",
            "model": {
                "type": "PROGRAM",
                "model": "IGNORED"
            }
        }
    ]
}
