{
  "name": "Counter Workflow",
  "steps": [
    {
      "name": "Run the Counter",
      "type": "task",
      "description": "Issues Generation",
      "prompt": "uv run ${RECON_FRAMEWORK_ROOT}/programs/increase_counter.py",
      "model": {
        "type": "PROGRAM",
        "model": "inherit"
      },
      "shouldCreateSummary": false,
      "shouldCommitChanges": false
    },
    {
      "name": "Check the Counter",
      "type": "decision",
      "description": "If counter is less than 10, continue, otherwise stop",
      "mode": "READ_FILE",
      "modeInfo": {
        "fileName": "Counter.md"
      },
      "decision": [
        {
          "operator": "lt",
          "value": 10,
          "action": "REPEAT_PREVIOUS_STEP"
        },
        {
          "operator": "gte",
          "value": 10,
          "action": "STOP"
        }
      ],
      "shouldCreateSummary": false,
      "shouldCommitChanges": false
    }
  ]
}