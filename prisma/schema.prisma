generator client {
  provider = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: We can't track events
// NOTE: I think logging externally would save time rather than maintaining it ourselves
model OrgInvite {
  id             String       @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
}

// Magic invite codes for free orgs to get magic job credits
model MagicInviteCode {
  id              String        @id @default(uuid())
  code            String        @unique // UUID by default, or custom memorable string
  createdAt       DateTime      @default(now())
  createdBy       String        // Super admin GitHub ID who created it

  // Redemption tracking (one org can redeem one code ever)
  redeemedAt      DateTime?
  redeemedByOrgId String?       @unique
  redeemedByOrg   Organization? @relation(fields: [redeemedByOrgId], references: [id])
}

// NOTE: These are listeners that allow automatic triggering of jobs
model Listener {
  id             String       @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  enabled        Boolean
}

model ApiKey {
  id             String       @id @default(uuid())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  createdAt      DateTime     @default(now())
  enabled        Boolean
  canWrite       Boolean @default(false)
  label String @default("")
}

model GovernanceFuzzing {
  id             String       @id @default(uuid())
  createdAt      DateTime     @default(now())
  enabled        Boolean      @default(true)
  eventDefinition String
  topic          String
  recipeId       String
  address        String
  chainId        Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  jobs           Job[]
  recipes        Recipe[]
  wsListenerId   String?
  wsListenerActive Boolean @default(false)
  lastCheckedBlock Int?
  lastCheckedAt DateTime?
}

//** == Organization ** == //
enum BILLING_STATUS {
  UNPAID
  PAID
  REVOKED // In case we need to ban people or smth
  TRIAL
}

model Organization {
  id   String @id @default(uuid())
  name String

  // TODO: We prob would want to attach some abiJobs and abiData Here
  // But also to User
  // The ones here are for everyone
  // The one for User are for User
  // By default we add here
  // Then for Legendary accounts
  // We can allow the User Option

  users User[]
  jobs  Job[]
  shares Share[]
  webhookJobs WebhookJob[]
  recipes Recipe[]
  campaigns Campaign[]
  recurringJobs RecurringJob[]
  liveMonitoring LiveMonitoring[]
  listeners Listener[]
  claudeJobs ClaudeJob[]

  // Magic credit system (for free orgs)
  magicCredits         Int              @default(0)
  redeemedInviteCode   MagicInviteCode?

  // NOTE: Projects are temporarily removed
  // projects  Project[]

  abiJobs   AbiJob[]
  abiData   ABIData[]
  invites   OrgInvite[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt

  // Billing
  billingStatus    BILLING_STATUS @default(UNPAID)
  billingUpdateAt DateTime @default(now())
  totalMinutesLeft Int @default(60) // Secret one extra hour
  governanceFuzzing GovernanceFuzzing[]
}

model Alert {
  id                String @id @default(uuid())
  active            Boolean @default(true)
  threshold         Int // From how many broken props I want to be informed
  webhookUrl        String
  recurringJob      RecurringJob? @relation(fields: [recurringJobId], references: [id])
  recurringJobId    String?
  recipe            Recipe? @relation(fields: [recipeId], references: [id])
  recipeId          String?
  telegramHandle    String?
  telegramChatId    Int?
}

// BILLING = AUTOMATED TOP

model User {
  id                       String       @id
  organization             Organization @relation(fields: [organizationId], references: [id])
  organizationId           String
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @default(now()) @updatedAt

  apiKey ApiKey[]
}

