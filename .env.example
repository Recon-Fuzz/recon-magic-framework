# =============================================================================
# Recon Unified Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# Framework — LLM Provider API Keys
# =============================================================================
# Anthropic Claude (REQUIRED if using "type": "CLAUDE_CODE" in workflows)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenCode (REQUIRED if using "type": "OPENCODE" in workflows)
# OPENCODE_API_KEY=your_opencode_key_here

# =============================================================================
# Framework — Optional Configuration
# =============================================================================
# Skip permissions prompts in CI/CD environments
# RUNNER_ENV=production

# Custom timeout values (in milliseconds)
# BASH_DEFAULT_TIMEOUT_MS=214748364
# BASH_MAX_TIMEOUT_MS=214748364

# LOG_LEVEL=INFO

# =============================================================================
# Runner — Database & Storage
# =============================================================================
DATABASE_URL=
S3_BUCKET=

# =============================================================================
# Runner — AWS Credentials
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# Backend (API) — ECS Job Execution
# =============================================================================
ECS_CLUSTER_NAME=
ECS_CONTAINER_NAME=
ECS_RUNNER_TASK_DEFINITION=
ECS_SECURITY_GROUP=
ECS_SUBNETS=

# =============================================================================
# Backend (API) — GitHub App Integration
# =============================================================================
GITHUB_APP_CLIENT_ID=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SECRET=
# GitHub token for inviting users to claude jobs
GHTOKEN=

# =============================================================================
# Backend (API) — Authentication & Secrets
# =============================================================================
# JWT secret for runner-to-backend authentication
JSON_WEB_TOKEN_SECRET_RUNNER=
# Claude integration secret
CLAUDE_SECRET=
# Private npm registry token
NPM_TOKEN=

# =============================================================================
# Backend (API) — CloudFront & Assets
# =============================================================================
AWS_ASSETS_URL=
AWS_CLOUDFRONT_DISTRIBUTION_DOMAIN=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY=

# =============================================================================
# Backend (API) — Factory & Monitoring
# =============================================================================
FACTORY_LISTENER_ADDRESS=
FACTORY_LISTENER_SECRET=
FUZZ_TIMEOUT=
PAPERTRAIL_API_TOKEN=

# =============================================================================
# Backend (API) — Notifications
# =============================================================================
TELEGRAM_BOT_TOKEN=
# Base URL for alert links
LINK_PREFIX=
